{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and metadata.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "personalRules": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "isActive": { "type": "boolean" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "URLGroup": {
      "title": "URL Group",
      "description": "A folder-like structure for organizing URLs and files.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "parentId": { "type": "string" },
        "projectAddress": { "type": "string" },
        "uid": { "type": "string", "description": "Owner UID" },
        "urls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "url": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "url": { "type": "string" },
              "mimeType": { "type": "string" },
              "size": { "type": "number" },
              "base64": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "uid"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a chat conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "ai", "system"] },
        "timestamp": { "type": "number" },
        "groupId": { "type": "string" },
        "uid": { "type": "string" }
      },
      "required": ["id", "text", "sender", "timestamp", "groupId", "uid"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Private user profile data."
    },
    "/groups/{groupId}": {
      "schema": "URLGroup",
      "description": "User's URL and file groups (folders)."
    },
    "/chats/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat message history."
    }
  }
}
